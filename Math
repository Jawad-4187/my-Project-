import pandas as pd
import numpy as np
from sklearn.metrics.pairwise import cosine_similarity
from sklearn.linear_model import LinearRegression

# --- PHASE 4: MATH BASICS (MANUAL CALCULATIONS) ---

# 1. Load Data
# loading the engineered features from phase 2
try:
    df = pd.read_csv('data/cleaned/AmesHousing_features.csv')
except FileNotFoundError:
    df = pd.read_csv('AmesHousing_features.csv')

# 2. Manual Mean and Std
# calculating mean and standard deviation manually using numpy
prices = df['SalePrice'].values
m_mean = np.sum(prices) / len(prices)
m_std = np.sqrt(np.sum((prices - m_mean)**2) / len(prices))

print(f"Manual Mean of SalePrice: {m_mean:.2f}")
print(f"Manual Std Dev of SalePrice: {m_std:.2f}")

# 3. Manual Z-Score
# standardizing the area column manually: (X - mean) / std
area = df['Gr_Liv_Area'].values
z_manual = (area - np.mean(area)) / np.std(area)
print(f"First 5 Manual Z-scores: {z_manual[:5]}")

# 4. Probability
# calculating the probability of price > 250k for high quality houses
high_qual = df[df['Overall_Qual'] >= 8]
prob = (high_qual['SalePrice'] > 250000).mean()
print(f"Probability (Price > 250k | Quality >= 8): {prob:.2%}")

# 5. Similarity
# measuring how similar the highest and lowest price houses are
cols = ['Gr_Liv_Area', 'Overall_Qual', 'Year_Built']
v1 = df.loc[df['SalePrice'].idxmax(), cols].values.reshape(1, -1)
v2 = df.loc[df['SalePrice'].idxmin(), cols].values.reshape(1, -1)

sim = cosine_similarity(v1, v2)
print(f"Similarity Score (Max vs Min): {sim[0][0]:.4f}")

# 6. R-Squared
# checking the strength of our new feature (Quality x Area)
X = df[['Quality_x_Area']]
y = df['SalePrice']
model = LinearRegression().fit(X, y)
print(f"R2 Score for our new feature: {model.score(X, y):.4f}")

print("Phase 4 Math Tasks Completed Successfully")
